{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "kintsugi",
  "plugin": ["oh-my-opencode-slim"],
  "keybinds": {
    "app_exit": "ctrl+q",
    "history_next": "alt+n",
    "history_previous": "alt+p",
    "input_delete_to_line_end": "none",
    "input_newline": "shift+return",
    "messages_first": "home,alt+g",
    "messages_last": "end,alt+shift+g",
    "messages_page_down": "pagedown,alt+f",
    "messages_page_up": "pageup,alt+b",
    "session_child_cycle": "alt+n",
    "session_child_cycle_reverse": "alt+p",
    "session_child_first": "alt+d",
    "session_list": "<leader>s",
    "session_parent": "alt+u",
    "status_view": "none",
    "theme_list": "none",
    "variant_cycle": "none",
    "variant_list": "<leader>t",
    "which_key_end": "none",
    "which_key_group_next": "tab",
    "which_key_group_previous": "shift+tab",
    "which_key_home": "none",
    "which_key_layout_toggle": "none",
    "which_key_page_down": "alt+n",
    "which_key_page_up": "alt+p",
    "which_key_pending_toggle": "none",
    "which_key_scroll_down": "down,alt+d",
    "which_key_scroll_up": "up,alt+u",
    "which_key_toggle": "ctrl+w"
  }
}
