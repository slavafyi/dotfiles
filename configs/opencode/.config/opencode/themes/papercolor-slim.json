{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkBackground": "#1c1c1c",
    "darkBackgroundPanel": "#262626",
    "darkBackgroundElement": "#303030",
    "darkForeground": "#d0d0d0",
    "darkMuted": "#808080",
    "darkBorder": "#585858",
    "darkPrimary": "#5fafd7",
    "darkSecondary": "#ff5faf",
    "darkAccent": "#00afaf",
    "darkError": "#af005f",
    "darkWarning": "#ffaf00",
    "darkSuccess": "#5faf00",
    "darkInfo": "#00afaf",
    "darkOrange": "#d7875f",
    "darkDiffAddedBg": "#293916",
    "darkDiffRemovedBg": "#3d1630",
    "darkDiffLineNumberBg": "#222222",
    "lightBackground": "#eeeeee",
    "lightBackgroundPanel": "#e4e4e4",
    "lightBackgroundElement": "#d7d7d7",
    "lightForeground": "#444444",
    "lightMuted": "#878787",
    "lightBorder": "#bcbcbc",
    "lightPrimary": "#0087af",
    "lightSecondary": "#8700af",
    "lightAccent": "#005f87",
    "lightError": "#af0000",
    "lightWarning": "#d75f00",
    "lightSuccess": "#008700",
    "lightInfo": "#005faf",
    "lightOrange": "#af5f00",
    "lightDiffAddedBg": "#d1e2d1",
    "lightDiffRemovedBg": "#ead1d1",
    "lightDiffLineNumberBg": "#dcdcdc"
  },
  "theme": {
    "primary": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "secondary": {
      "dark": "darkSecondary",
      "light": "lightSecondary"
    },
    "accent": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "error": {
      "dark": "darkError",
      "light": "lightError"
    },
    "warning": {
      "dark": "darkWarning",
      "light": "lightWarning"
    },
    "success": {
      "dark": "darkSuccess",
      "light": "lightSuccess"
    },
    "info": {
      "dark": "darkInfo",
      "light": "lightInfo"
    },
    "text": {
      "dark": "darkForeground",
      "light": "lightForeground"
    },
    "textMuted": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "background": {
      "dark": "darkBackground",
      "light": "lightBackground"
    },
    "backgroundPanel": {
      "dark": "darkBackgroundPanel",
      "light": "lightBackgroundPanel"
    },
    "backgroundElement": {
      "dark": "darkBackgroundElement",
      "light": "lightBackgroundElement"
    },
    "border": {
      "dark": "darkBorder",
      "light": "lightBorder"
    },
    "borderActive": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "borderSubtle": {
      "dark": "darkBackgroundElement",
      "light": "lightBackgroundElement"
    },
    "diffAdded": {
      "dark": "darkSuccess",
      "light": "lightSuccess"
    },
    "diffRemoved": {
      "dark": "darkError",
      "light": "lightError"
    },
    "diffContext": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "diffHunkHeader": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "diffHighlightAdded": {
      "dark": "#afd700",
      "light": "lightSuccess"
    },
    "diffHighlightRemoved": {
      "dark": "#ff5faf",
      "light": "lightError"
    },
    "diffAddedBg": {
      "dark": "darkDiffAddedBg",
      "light": "lightDiffAddedBg"
    },
    "diffRemovedBg": {
      "dark": "darkDiffRemovedBg",
      "light": "lightDiffRemovedBg"
    },
    "diffContextBg": {
      "dark": "darkBackgroundPanel",
      "light": "lightBackgroundPanel"
    },
    "diffLineNumber": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "diffAddedLineNumberBg": {
      "dark": "darkDiffLineNumberBg",
      "light": "lightDiffLineNumberBg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "darkDiffLineNumberBg",
      "light": "lightDiffLineNumberBg"
    },
    "markdownText": {
      "dark": "darkForeground",
      "light": "lightForeground"
    },
    "markdownHeading": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "markdownLink": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "markdownLinkText": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "markdownCode": {
      "dark": "darkOrange",
      "light": "lightOrange"
    },
    "markdownBlockQuote": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "markdownEmph": {
      "dark": "darkWarning",
      "light": "lightWarning"
    },
    "markdownStrong": {
      "dark": "darkForeground",
      "light": "lightForeground"
    },
    "markdownHorizontalRule": {
      "dark": "darkBorder",
      "light": "lightBorder"
    },
    "markdownListItem": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "markdownListEnumeration": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "markdownImage": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "markdownImageText": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "markdownCodeBlock": {
      "dark": "darkForeground",
      "light": "lightForeground"
    },
    "syntaxComment": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "syntaxKeyword": {
      "dark": "darkSecondary",
      "light": "lightSecondary"
    },
    "syntaxFunction": {
      "dark": "darkPrimary",
      "light": "lightPrimary"
    },
    "syntaxVariable": {
      "dark": "darkForeground",
      "light": "lightForeground"
    },
    "syntaxString": {
      "dark": "darkSuccess",
      "light": "lightSuccess"
    },
    "syntaxNumber": {
      "dark": "darkWarning",
      "light": "lightWarning"
    },
    "syntaxType": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "syntaxOperator": {
      "dark": "darkAccent",
      "light": "lightAccent"
    },
    "syntaxPunctuation": {
      "dark": "darkMuted",
      "light": "lightMuted"
    }
  }
}
