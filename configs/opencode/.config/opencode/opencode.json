{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.5",
  "instructions": ["~/AGENTS.md"],
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "build": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "shopify-dev": {
      "type": "local",
      "command": ["pnpx", "@shopify/dev-mcp@latest"],
      "environment": {
        "LIQUID_VALIDATION_MODE": "full",
        "OPT_OUT_INSTRUMENTATION": "true"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["pnpx", "chrome-devtools-mcp@latest", "--autoConnect"]
    },
    "context-mode": {
      "type": "local",
      "command": ["pnpx", "--allow-build=better-sqlite3", "context-mode@latest"]
    }
  },
  "lsp": {
    "shopify-theme": {
      "command": ["shopify", "theme", "language-server"],
      "extensions": [".liquid"]
    }
  },
  "plugin": ["context-mode", "opencode-wakatime", "oh-my-opencode-slim"]
}
