{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.5",
  "instructions": ["~/AGENTS.md"],
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "build": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "shopify-dev": {
      "type": "local",
      "command": [
        "pnpx",
        "@shopify/dev-mcp@latest"
      ],
      "environment": {
        "LIQUID_VALIDATION_MODE": "full",
        "OPT_OUT_INSTRUMENTATION": "true"
      }
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_PAT}"
      }
    },
    "railway": {
      "type": "local",
      "command": [
        "pnpx",
        "@railway/mcp-server"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["pnpx", "chrome-devtools-mcp@latest"]
    }
  },
  "lsp": {
    "shopify-theme": {
      "command": [
        "shopify",
        "theme",
        "language-server"
      ],
      "extensions": [
        ".liquid"
      ]
    }
  },
  "plugin": [
    "opencode-wakatime"
  ]
}
