{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": true,
  "model": "openai/gpt-5.3-codex",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.2-pro"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "shopify-dev": {
      "type": "local",
      "command": ["pnpx", "@shopify/dev-mcp@latest"],
      "environment": {
        "LIQUID_VALIDATION_MODE": "full",
        "OPT_OUT_INSTRUMENTATION": "true"
      }
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_PAT}"
      }
    }
  },
  "lsp": {
    "shopify-theme": {
      "command": ["shopify", "theme", "language-server"],
      "extensions": [".liquid"]
    }
  },
  "tools": {
    "context7": true,
    "shopify-dev": true,
    "github": true
  }
}
