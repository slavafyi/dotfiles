{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.6-terra",
  "instructions": ["~/AGENTS.md"],
  "default_agent": "orchestrator",
  "agent": {
    "title": {
      "model": "openai/gpt-5.6-terra",
      "variant": "low"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "variant": "max"
    },
    "build": {
      "model": "openai/gpt-5.6-terra",
      "variant": "high"
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["pnpx", "chrome-devtools-mcp@latest", "--autoConnect"]
    }
  },
  "lsp": {
    "shopify-theme": {
      "command": ["shopify", "theme", "language-server"],
      "extensions": [".liquid"]
    }
  },
  "plugin": ["opencode-wakatime", "oh-my-opencode-slim"]
}
