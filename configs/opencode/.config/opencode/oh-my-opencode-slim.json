{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "default",
  "presets": {
    "default": {
      "council": { "model": "openai/gpt-5.5", "variant": "xhigh" },
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": "openai/gpt-5.5-fast",
        "variant": "high",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": "openai/gpt-5.3-codex-spark",
        "variant": "low",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": "openai/gpt-5.3-codex-spark",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "openai/gpt-5.5-fast",
        "variant": "high",
        "skills": ["agent-browser"],
        "mcps": []
      },
      "fixer": {
        "model": "openai/gpt-5.3-codex-spark",
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    }
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 50
  },
  "council": {
    "timeout": 1000000,
    "presets": {
      "default": {
        "alpha": {
          "model": "opencode-go/kimi-k2.6"
        },
        "beta": {
          "model": "opencode-go/minimax-m2.7"
        },
        "gamma": {
          "model": "opencode-go/deepseek-v4-pro"
        }
      }
    }
  }
}
