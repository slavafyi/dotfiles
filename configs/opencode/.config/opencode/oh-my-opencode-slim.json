{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "default",
  "presets": {
    "default": {
      "council": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh"
      },
      "designer": {
        "model": "openai/gpt-5.5-fast",
        "variant": "high",
        "skills": ["agent-browser"],
        "mcps": []
      },
      "explorer": {
        "model": "openai/gpt-5.3-codex-spark",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": "openai/gpt-5.3-codex-spark",
        "skills": [],
        "mcps": []
      },
      "oracle": {
        "model": "openai/gpt-5.5-fast",
        "variant": "high",
        "skills": ["simplify"],
        "mcps": []
      },
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "librarian": {
        "model": "openai/gpt-5.3-codex-spark",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      }
    }
  },
  "council": {
    "default_preset": "default",
    "presets": {
      "default": {
        "alpha": { "model": "opencode-go/kimi-k2.6" },
        "beta": { "model": "opencode-go/minimax-m2.7" },
        "gamma": { "model": "opencode-go/deepseek-v4-pro" }
      },
      "second-opinion": {
        "architect": {
          "model": "openai/gpt-5.4",
          "variant": "high",
          "prompt": "Review the task and the likely implementation for architecture, boundaries, coupling, long-term maintainability, migration/data risk, API design, and operational risk. Argue against weak designs. Propose safer alternatives."
        },
        "critic": {
          "model": "openai/gpt-5.3-codex",
          "variant": "high",
          "prompt": "Find missing requirements, weak assumptions, unhandled edge cases, test gaps, security/data risks, and unclear verification. End with exactly one verdict: APPROVE, ITERATE, or REJECT, with reasons."
        }
      }
    },
    "timeout": 900000
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 50
  }
}
